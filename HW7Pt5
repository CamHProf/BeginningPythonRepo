def gcd(a, b):
    """Euclidean algorithm for GCD."""
    while b:
        a, b = b, a % b
    return a

def phi(n):
    """Returns list of numbers relatively prime to n."""
    return [k for k in range(1, n) if gcd(n, k) == 1]

def main():
    n = int(input("Enter n: "))
    relatively_prime = phi(n)
    print(f"Numbers relatively prime to {n}: {relatively_prime}")
    print(f"φ({n}) = {len(relatively_prime)}")

if __name__ == "__main__": main()
