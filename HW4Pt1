from graphics import *
import math

# Get user input
num_sides = int(input("Number of sides: "))
radius = int(input("Radius: "))

# Create window
win = GraphWin("Regular Polygon", 600, 600)
center_point = Point(300, 300)

# Compute vertices
vertices_list = []
angle_between_sides = 360 / num_sides
for side_index in range(num_sides):
    angle_radians = math.radians(side_index * angle_between_sides)
    x_coord = center_point.getX() + radius * math.cos(angle_radians)
    y_coord = center_point.getY() + radius * math.sin(angle_radians)
    vertices_list.append(Point(x_coord, y_coord))

# Draw polygon
polygon_shape = Polygon(vertices_list)
polygon_shape.setFill("lightblue")
polygon_shape.draw(win)

# Wait for click, then close
win.getMouse()
win.close()
