from graphics import *
import math

num_sides = int(input("Number of sides: "))
radius = int(input("Radius: "))

win = GraphWin("Regular Polygon", 600, 600)
center = Point(300, 300)

vertices = []
angle_step = 360 / num_sides

for i in range(num_sides):
    angle_rad = math.radians(i * angle_step)
    x = center.getX() + radius * math.cos(angle_rad)
    y = center.getY() + radius * math.sin(angle_rad)
    vertices.append(Point(x, y))

polygon = Polygon(vertices)
polygon.draw(win)

win.getMouse()
win.close()
