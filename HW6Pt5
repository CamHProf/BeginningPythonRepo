def is_prime(number):
    if number < 2:
        return False
    for divisor in range(2, number):
        if number % divisor == 0:
            return False
    return True

def check_prime():
    user_number = int(input("Enter a number to check for primality: "))
    if is_prime(user_number):
        print(user_number, "is a prime number")
    else:
        print(user_number, "is NOT a prime number")

check_prime()
